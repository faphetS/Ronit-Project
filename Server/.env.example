NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
TZ=Asia/Jerusalem

# --- Monday.com ---
# Personal API token from https://<account>.monday.com/apps/manage/tokens
# Optional today (no domain uses it yet); becomes required when the monday domain lands.
MONDAY_API_TOKEN=

# Board / group / column IDs — defaults in env.ts match the current CRM snapshot.
# Set these only if the CRM board structure changes.
MONDAY_BOARD_CRM_ID=
MONDAY_GROUP_NEW_LEADS_ID=
MONDAY_COL_PHONE_ID=
MONDAY_COL_SERVICE_ID=
MONDAY_COL_NOTES_ID=

# Service board IDs — items move here when a CRM lead is closed.
# Challah is the 2026 board; later-year boards auto-create on demand.
# Uman is the bootstrap flight board; later flights auto-create when the current
# flight's date passes. Current Uman board ID is persisted in SQLite.
MONDAY_BOARD_UMAN_ID=
MONDAY_BOARD_CHALLAH_ID=

# Uman board — per-row flight date column. Ronit fills this manually.
MONDAY_UMAN_COL_DATE_ID=

# --- Meta / Instagram ---
# Set when the Meta developer app is created and business verification is done.
META_APP_SECRET=
META_VERIFY_TOKEN=

# Optional first-contact auto-reply templates (code defaults exist; leave unset to
# use them, or override here — value must be non-empty). The auto-reply picks one
# of four by (did the lead name a service?) x (was a phone number in the message?):
#   service named  + phone present -> IG_MSG_SERVICE_PHONE_PRESENT  (neutral)
#   service named  + phone missing -> IG_MSG_SERVICE_PHONE_MISSING  (neutral, asks for phone)
#   no service     + phone present -> IG_MSG_PHONE_PRESENT          (Uman teaser + {form_link})
#   no service     + phone missing -> IG_MSG_PHONE_MISSING          (Uman teaser + {form_link}, asks for phone)
# IG_MSG_SERVICE_PHONE_PRESENT=
# IG_MSG_SERVICE_PHONE_MISSING=
# IG_MSG_PHONE_PRESENT=
# IG_MSG_PHONE_MISSING=

# --- SQLite ---
# Default lives on the Docker volume /opt/ronit-data → /data inside the container.
# Override for local dev (e.g. ./crm.sqlite) so writes don't require /data to exist.
DB_FILE_PATH=

# --- OpenRouter ---
# API key from https://openrouter.ai/keys. Required when the classifier is invoked.
OPENROUTER_API_KEY=
# Override to swap models without code changes.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Group ID for the "Closed" group — leads here won't be moved to Contacted on calls.
MONDAY_GROUP_CLOSED_ID=

# --- Salestrail — call recording webhook + Pull API ---
SALESTRAIL_WEBHOOK_USERNAME=
SALESTRAIL_WEBHOOK_PASSWORD=
# Audio transcription model — default is Gemini 2.5 Flash via OpenRouter.
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

# --- GreenAPI / WhatsApp ---
GREENAPI_API_URL=https://7103.api.greenapi.com
GREENAPI_INSTANCE_ID=
GREENAPI_API_TOKEN=
RONIT_OWNER_WA_NUMBER=
